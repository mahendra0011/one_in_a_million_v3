# ── Server ──────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/one-in-a-million
JWT_SECRET=your-super-secret-jwt-key-here
PORT=3001
CLIENT_URL=http://localhost:5173
SETUP_SECRET=your-setup-secret

# ── Cloudinary ──────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=one-in-a-million/images

# ── Brevo — Email OTP (REST API, NOT SMTP) ──────────────────────
# 1. brevo.com → Account → Settings → API Keys → Generate
# 2. Verified sender email set karo Brevo dashboard mein
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@oneinamillion.com
BREVO_SENDER_NAME=One in a Million

# ── Google OAuth ───────────────────────────────────────────────────
# 1. console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID → Web application
# 3. Authorized redirect URI: http://localhost:5173/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
SERVER_URL=http://localhost:5173

# ── Redis (for Socket.io adapter) ─────────────────────────────
# Render free Redis URL (50MB instance)
REDIS_URL=redis://red-d99b8mf7f7vs73a4u9b0:6379

# ── OpenRouteService (for routing + map matching) ───────────────────────────────
ORS_API_KEY=your-ors-api-key

# ── MapTiler (for geocoding + map tiles) ───────────────────────────────────
MAPTILER_API_KEY=your-maptiler-api-key

# ── Admin credentials (auto-created on startup) ───────────────────────────────
ADMIN_EMAIL=admin@oneinamillion.com
ADMIN_PASSWORD=your-admin-password
ADMIN_PHONE=+919999999999
