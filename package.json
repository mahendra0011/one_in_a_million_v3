{
  "name": "one-in-a-million",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n SERVER,VITE -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "seed:menu": "cd server && node seed-menu.js",
    "seed:users": "cd server && node seed-users.js"
  },
  "overrides": {
    "react-helmet-async": {
      "react": "$react"
    }
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@reduxjs/toolkit": "^2.12.0",
    "@tanstack/react-query": "^5.101.0",
    "cloudinary": "^2.10.0",
    "concurrently": "^9.1.2",
    "express-fileupload": "^1.5.2",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "lightswind": "^3.1.37",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^2.0.5",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.0",
    "socket.io-client": "^4.8.1",
    "three": "^0.184.0",
    "vite-plugin-pwa": "^0.21.1",
    "workbox-window": "^7.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.12"
  }
}
